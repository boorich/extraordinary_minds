{
  "debug": false,
  "entry": [
    "pages/**/*.{js,jsx,ts,tsx}",
    "components/**/*.{js,jsx,ts,tsx}",
    "lib/**/*.{js,jsx,ts,tsx}",
    "src/**/*.{js,jsx,ts,tsx}"
  ],
  "extensions": [".js", ".jsx", ".ts", ".tsx"],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/*.test.*",
    "**/*.spec.*",
    ".next/**"
  ]
}